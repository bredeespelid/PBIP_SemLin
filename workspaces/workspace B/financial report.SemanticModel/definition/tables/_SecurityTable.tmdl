/// Security mapping table for dynamic RLS — maps user emails to allowed countries
table _SecurityTable
	isHidden
	lineageTag: a1b2c3d4-e5f6-4789-abcd-112233445566

	/// User principal name (email) for RLS lookup
	column UserEmail
		dataType: string
		displayFolder: Security
		lineageTag: b2c3d4e5-f6a7-4890-bcde-223344556677
		summarizeBy: none
		isNameInferred
		sourceColumn: [UserEmail]

	/// Country the user is authorized to see
	column Country
		dataType: string
		displayFolder: Security
		lineageTag: c3d4e5f6-a7b8-4901-cdef-334455667788
		summarizeBy: none
		isNameInferred
		sourceColumn: [Country]

	partition _SecurityTable-Partition = calculated
		mode: import
		source =
				DATATABLE(
					"UserEmail", STRING,
					"Country", STRING,
					{
						{"test.user1@mollerdigital.no", "United States of America"},
						{"test.user2@mollerdigital.no", "Canada"},
						{"test.user3@mollerdigital.no", "France"},
						{"test.user4@mollerdigital.no", "Germany"},
						{"test.user5@mollerdigital.no", "Mexico"},
						{"admin@mollerdigital.no", "United States of America"},
						{"admin@mollerdigital.no", "Canada"},
						{"admin@mollerdigital.no", "France"},
						{"admin@mollerdigital.no", "Germany"},
						{"admin@mollerdigital.no", "Mexico"}
					}
				)

